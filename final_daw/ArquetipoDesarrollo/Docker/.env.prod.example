# Copiar este fichero a .env.prod y rellenar con los valores reales.


# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DJANGO_SETTINGS_MODULE=core.settings.production

# PostgreSQL
POSTGRES_DB=pomba_db
POSTGRES_USER=pomba_user
POSTGRES_PASSWORD=cambia-esto-por-una-contraseña-segura
DB_NAME=pomba_db
DB_USER=pomba_user
DB_PASSWORD=cambia-esto-por-una-contraseña-segura
DB_HOST=db
DB_PORT=5432

# Garage S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=mi-bucket-app
AWS_S3_ENDPOINT_URL=http://garage:3900
AWS_S3_REGION_NAME=garage
GARAGE_RPC_SECRET=cambia-esto-por-un-secreto-largo
# URL pública para presigned URLs — el navegador sube directo a este endpoint
GARAGE_PUBLIC_URL=https://pomba.app:3900

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
